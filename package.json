{
  "name": "@kekemoto/signals",
  "version": "0.1.0",
  "description": "最小リアクティブシステム（signal / effect / memo / reactive）と DOM ユーティリティ",
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "unpkg": "./dist/signals.global.min.js",
  "jsdelivr": "./dist/signals.global.min.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./reactive": {
      "types": "./dist/src/reactive.d.ts",
      "default": "./dist/src/reactive.js"
    },
    "./h": {
      "types": "./dist/src/h.d.ts",
      "default": "./dist/src/h.js"
    },
    "./tags": {
      "types": "./dist/src/tags.d.ts",
      "default": "./dist/src/tags.js"
    },
    "./for": {
      "types": "./dist/src/for.d.ts",
      "default": "./dist/src/for.js"
    },
    "./show": {
      "types": "./dist/src/show.d.ts",
      "default": "./dist/src/show.js"
    },
    "./element": {
      "types": "./dist/src/element.d.ts",
      "default": "./dist/src/element.js"
    }
  },
  "files": [
    "dist/src",
    "dist/signals.global.js",
    "dist/signals.global.js.map",
    "dist/signals.global.min.js",
    "src"
  ],
  "scripts": {
    "build": "tsc && npm run build:global",
    "build:global": "esbuild dist/src/index.js --bundle --format=iife --global-name=Signals --outfile=dist/signals.global.js --sourcemap && esbuild dist/src/index.js --bundle --format=iife --global-name=Signals --minify --outfile=dist/signals.global.min.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node dist/test/test-core.js && node dist/test/test-owner.js",
    "test:dom": "npm run build && node dist/test/test-dom.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "signals",
    "reactive",
    "fine-grained",
    "dom",
    "typescript"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kekemoto/signals.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3"
  }
}
